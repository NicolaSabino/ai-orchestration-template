# Model Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
TEMPERATURE=0.7

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=orchestrator.log

# Optional: OpenAI Configuration (uncomment to use OpenAI instead of Ollama)
# OPENAI_API_KEY=your-api-key-here
# OPENAI_MODEL=gpt-4

# Observability Configuration (Langfuse)
# Enable/disable tracing - set to 'false' to disable completely
ENABLE_TRACING=true

# Langfuse Cloud Configuration (default)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# Self-hosted Langfuse (uncomment and set LANGFUSE_HOST to your instance)
# LANGFUSE_HOST=http://localhost:3000

# SECURITY NOTE: Traces may contain user queries and LLM responses.
# Use self-hosted Langfuse or disable tracing if handling sensitive data.
